<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <connectionStrings>
    <!--
      Измени Server и Database под свою среду.
      Integrated Security=True  →  Windows-аутентификация (не нужен логин/пароль).
      TrustServerCertificate=True  →  обязательно для SQL Server Express без сертификата.
    -->
    <add name="DefaultConnection"
         connectionString="Server=.\SQLEXPRESS;Database=School_event;Integrated Security=True;TrustServerCertificate=True;"
         providerName="Microsoft.Data.SqlClient"/>
  </connectionStrings>

  <appSettings>
    <!--
      Путь к папке с изображениями мероприятий.

      Варианты:
        Локальная папка (один ПК / отладка):
          <add key="ImagesPath" value="C:\SchoolEventImages\" />

        Сетевая папка (несколько ПК в одной сети — рекомендуется):
          <add key="ImagesPath" value="\\SERVER\SchoolEventImages\" />

      Папка создаётся автоматически при первом запуске приложения.
      Все клиентские ПК должны иметь права на чтение и запись в эту папку.
    -->
    <add key="ImagesPath" value="C:\SchoolEventImages\" />
  </appSettings>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
  </startup>
</configuration>