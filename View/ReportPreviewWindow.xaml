<Window x:Class="SchoolEventApp.ReportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Просмотр отчёта"
        WindowStartupLocation="CenterOwner"
        Width="950" Height="720"
        MinWidth="600" MinHeight="400"
        FontFamily="Segoe UI" FontSize="13">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="18,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="📄" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="tbReportTitle" Text="Отчёт"
                           Foreground="White" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Кнопки -->
        <Border Grid.Row="1" Background="#F4F6F8" Padding="14,10">
            <WrapPanel Orientation="Horizontal">

                <Button x:Name="btnPrint"
                        Content="🖨  Печать"
                        Click="btnPrint_Click"
                        Width="110" Height="36" Margin="0,0,8,0"
                        Background="#8E44AD" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="13"/>

                <Button x:Name="btnSavePdf"
                        Content="💾  PDF"
                        Click="btnSavePdf_Click"
                        Width="90" Height="36" Margin="0,0,8,0"
                        Background="#27AE60" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="13"/>

                <Button x:Name="btnExportWord"
                        Content="📝  Word"
                        Click="btnExportWord_Click"
                        Width="100" Height="36" Margin="0,0,8,0"
                        Background="#2E4699" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="13"/>

                <Button x:Name="btnExportExcel"
                        Content="📊  Excel"
                        Click="btnExportExcel_Click"
                        Width="100" Height="36" Margin="0,0,8,0"
                        Background="#1A6B3C" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="13"/>

                <Button x:Name="btnClose"
                        Content="✖  Закрыть"
                        Click="btnClose_Click"
                        Width="110" Height="36"
                        Background="#E74C3C" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="13"/>

            </WrapPanel>
        </Border>

        <!-- Предпросмотр PDF через WebView2 -->
        <Border Grid.Row="2" Background="#888">
            <wv2:WebView2 x:Name="webView" />
        </Border>

        <!-- Строка статуса -->
        <Border Grid.Row="3" Background="#ECF0F1" BorderBrush="#DDE"
                BorderThickness="0,1,0,0" Padding="14,6">
            <DockPanel>
                <TextBlock x:Name="tbRowCount" DockPanel.Dock="Right"
                           Foreground="#2980B9" FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="tbStatus" Foreground="#555"
                           FontSize="11" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
