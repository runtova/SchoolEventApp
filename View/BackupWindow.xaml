<Window x:Class="SchoolEventApp.BackupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Резервное копирование"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="#F5F6F8">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Style/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Style="{StaticResource FormHeaderStyle}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🗄" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="Резервное копирование базы данных"
                               Style="{StaticResource FormHeaderTextStyle}"/>
                    <TextBlock Text="School_event · SQL Server Express"
                               Foreground="{StaticResource Ink500Brush}"
                               FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Тело -->
        <StackPanel Grid.Row="1" Margin="28,20,28,8">

            <!-- ── БЛОК: СОЗДАТЬ КОПИЮ ── -->
            <Border Background="White" BorderBrush="{StaticResource Ink100Brush}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="СОЗДАТЬ РЕЗЕРВНУЮ КОПИЮ"
                               Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,8"/>

                    <TextBlock Text="Папка сохранения:" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="tbBackupFolder"
                                 Style="{StaticResource InputStyle}"
                                 IsReadOnly="True"
                                 Background="{StaticResource Ink50Brush}"
                                 Foreground="{StaticResource Ink500Brush}"
                                 VerticalContentAlignment="Center"
                                 Height="36"/>
                        <Button Grid.Column="1" Content="Обзор…"
                                Click="BrowseBackupFolder_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="8,0,0,0" Padding="12,7" Height="36"/>
                    </Grid>

                    <Button x:Name="btnBackup" Content="💾  Создать резервную копию"
                            Click="Backup_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="40" Margin="0,12,0,0" FontSize="13"/>

                    <!-- Прогресс -->
                    <ProgressBar x:Name="pbBackup" Height="4" Margin="0,10,0,0"
                                 IsIndeterminate="False" Value="0"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="{StaticResource Ink100Brush}"
                                 Visibility="Collapsed"/>

                    <TextBlock x:Name="tbBackupStatus" FontSize="12"
                               Foreground="{StaticResource Ink500Brush}"
                               TextWrapping="Wrap" Margin="0,6,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- ── БЛОК: ВОССТАНОВИТЬ ── -->
            <Border Background="White" BorderBrush="{StaticResource Ink100Brush}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="ВОССТАНОВИТЬ ИЗ ФАЙЛА"
                               Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,8"/>

                    <TextBlock Text="Выберите файл резервной копии (.bak):"
                               Style="{StaticResource FieldLabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="tbRestoreFile"
                                 Style="{StaticResource InputStyle}"
                                 IsReadOnly="True"
                                 Background="{StaticResource Ink50Brush}"
                                 Foreground="{StaticResource Ink500Brush}"
                                 VerticalContentAlignment="Center"
                                 Height="36"/>
                        <Button Grid.Column="1" Content="Выбрать…"
                                Click="BrowseRestoreFile_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="8,0,0,0" Padding="12,7" Height="36"/>
                    </Grid>

                    <!-- Предупреждение -->
                    <Border Background="#FFF8E1" BorderBrush="#FFE082"
                            BorderThickness="1" CornerRadius="5"
                            Padding="12,8" Margin="0,10,0,0">
                        <TextBlock Text="⚠  Восстановление заменит все текущие данные. Приложение автоматически закроется после завершения."
                                   FontSize="12" Foreground="#7B6000" TextWrapping="Wrap"/>
                    </Border>

                    <Button x:Name="btnRestore" Content="🔄  Восстановить базу данных"
                            Click="Restore_Click"
                            Style="{StaticResource DangerButtonStyle}"
                            Height="40" Margin="0,12,0,0" FontSize="13"
                            IsEnabled="False"/>

                    <!-- Прогресс восстановления -->
                    <ProgressBar x:Name="pbRestore" Height="4" Margin="0,10,0,0"
                                 IsIndeterminate="True"
                                 Foreground="{StaticResource DangerBrush}"
                                 Background="{StaticResource Ink100Brush}"
                                 Visibility="Collapsed"/>

                    <TextBlock x:Name="tbRestoreStatus" FontSize="12"
                               Foreground="{StaticResource Ink500Brush}"
                               TextWrapping="Wrap" Margin="0,6,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- Кнопка закрытия -->
        <Border Grid.Row="2" Style="{StaticResource ActionPanelStyle}">
            <Button Content="Закрыть" Click="Close_Click"
                    Style="{StaticResource SecondaryButtonStyle}"
                    HorizontalAlignment="Right" Padding="24,9"/>
        </Border>
    </Grid>
</Window>
