<Window x:Class="SchoolEventApp.ParticipantsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Участники мероприятия"
        Width="640" Height="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FontFamily="Segoe UI" FontSize="13">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="👥" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="tbTitle" Text="Участники"
                           Foreground="White" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="tbCount" Text=""
                           Foreground="#BDC3C7" FontSize="13"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Таблица -->
        <DataGrid Grid.Row="1" x:Name="dgParticipants"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserDeleteRows="False"
                  CanUserAddRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F9FAFB"
                  Margin="8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№"
                                    Binding="{Binding RowNumber}"
                                    Width="45"/>
                <DataGridTextColumn Header="ФИО"
                                    Binding="{Binding student_FIO}"
                                    Width="*"/>
                <DataGridTextColumn Header="Класс"
                                    Binding="{Binding class}"
                                    Width="70"/>
                <DataGridTextColumn Header="Телефон"
                                    Binding="{Binding phone_number_s}"
                                    Width="140"/>
                <DataGridTextColumn Header="Email"
                                    Binding="{Binding email_s}"
                                    Width="180"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <Border Grid.Row="2" Background="#F4F6F8"
                BorderBrush="#DDE" BorderThickness="0,1,0,0" Padding="16,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="&#128194; Экспорт в Excel"
                            Click="ExportExcel_Click"
                            Padding="14,7" Margin="0,0,8,0"
                            Background="#1D6A39" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontSize="12"/>
                    <Button Content="&#128196; Экспорт в PDF"
                            Click="ExportPdf_Click"
                            Padding="14,7"
                            Background="#C0392B" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontSize="12"/>
                </StackPanel>
                <Button Content="Закрыть" Click="Close_Click"
                        Width="90" Padding="0,7"
                        Background="#BDC3C7" Foreground="#222"
                        BorderThickness="0" Cursor="Hand"
                        HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
