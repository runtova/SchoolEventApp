<Window x:Class="SchoolEventApp.AddEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мероприятие"
        WindowStartupLocation="CenterOwner"
        WindowState="Normal"
        ResizeMode="NoResize"
        Width="540" SizeToContent="Height"
        MaxHeight="700"
        Background="White"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Style/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="White"
          FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Style="{StaticResource FormHeaderStyle}">
            <StackPanel>
                <TextBlock x:Name="tbTitle" Text="Добавление мероприятия"
                           Style="{StaticResource FormHeaderTextStyle}"/>
                <TextBlock x:Name="tbCodLabel" Text=""
                           Foreground="#9CA3AF" FontSize="12" Margin="0,3,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- Поля -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Padding="28,20,28,8">
            <StackPanel>

                <!-- Код (только при редактировании) -->
                <StackPanel x:Name="panelCod" Visibility="Collapsed">
                    <TextBlock Text="КОД" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="tbCod" Style="{StaticResource ReadOnlyFieldStyle}"
                             Height="36"/>
                </StackPanel>

                <TextBlock Text="НАЗВАНИЕ" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="tbName" Style="{StaticResource FieldBoxStyle}"
                         Height="36"/>

                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ДАТА" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker x:Name="dpDate" Style="{StaticResource FieldDateStyle}"
                                    Height="36"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ВРЕМЯ (чч:мм)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="tbTime" Style="{StaticResource FieldBoxStyle}"
                                 Height="36"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="МЕСТО" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="tbPlace" Style="{StaticResource FieldBoxStyle}"
                         Height="36"/>

                <TextBlock Text="ОРГАНИЗАТОР" Style="{StaticResource FieldLabelStyle}"/>
                <ComboBox x:Name="cbOrganizer" Style="{StaticResource FieldComboStyle}"
                          Height="36"
                          DisplayMemberPath="DisplayText"
                          SelectedValuePath="organizer_cod"
                          DropDownOpened="cbOrganizer_DropDownOpened"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ТИП" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="tbType" Style="{StaticResource FieldBoxStyle}"
                                 Height="36"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="МАКС. МЕСТ" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="tbMaxParticipants"
                                 Style="{StaticResource FieldBoxStyle}"
                                 Height="36" Text="0"
                                 ToolTip="0 — без ограничений"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="КАРТИНКА" Style="{StaticResource FieldLabelStyle}"/>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="tbImagePath"
                                 Style="{StaticResource ReadOnlyFieldStyle}"
                                 Width="280" Height="36"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Путь к файлу картинки"/>
                        <Button Content="Выбрать..."
                                Click="PickImage_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="8,0,0,0" Padding="12,0" Height="36"/>
                        <Button Content="✕"
                                Click="ClearImage_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="6,0,0,0" Padding="10,0" Height="36"
                                ToolTip="Удалить картинку"/>
                    </StackPanel>
                    <Border Margin="0,8,0,0" Width="240" Height="120"
                            HorizontalAlignment="Left"
                            BorderBrush="#E8EBF0" BorderThickness="1"
                            CornerRadius="6" Background="#F5F6F8">
                        <Image x:Name="imgPreview" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                </StackPanel>

                <!-- Ошибка -->
                <Border x:Name="borderError" Visibility="Collapsed"
                        Background="#FCECEA" BorderBrush="#DEC0BD"
                        BorderThickness="1" CornerRadius="5"
                        Padding="12,8" Margin="0,12,0,4">
                    <TextBlock x:Name="tbError"
                               Style="{StaticResource ErrorTextStyle}"
                               Margin="0"/>
                </Border>

                <Rectangle Height="8"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <Border Grid.Row="2" Style="{StaticResource ActionPanelStyle}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена"
                        Click="Cancel_Click"
                        Style="{StaticResource CancelButtonStyle}"
                        Padding="20,9" Margin="0,0,8,0"/>
                <Button Content="Сохранить"
                        Click="Save_Click"
                        Style="{StaticResource SaveButtonStyle}"
                        Padding="24,9"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
