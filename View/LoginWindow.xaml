<Window x:Class="SchoolEventApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="School Event — Вход"
        Width="400"
        MinHeight="400" MaxHeight="800"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="#F5F6F8">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Style/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
        <!-- Центральная карточка -->
        <Border Background="White" CornerRadius="12"
                Margin="28">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" Opacity="0.10"
                                  ShadowDepth="0" Color="#000000"/>
            </Border.Effect>

            <StackPanel>

                <!-- Шапка -->
                <Border CornerRadius="12,12,0,0" Padding="32,28,32,24"
                        Background="#2D3142">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="School Event"
                                   Foreground="White"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="22"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Система учёта мероприятий"
                                   Foreground="#6B7C9A"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Тело -->
                <StackPanel Margin="32,24,32,32">

                    <!-- Переключатель Вход / Регистрация -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnTabLogin" Grid.Column="0"
                                Content="Вход"
                                Click="TabLogin_Click"
                                Height="36"
                                BorderThickness="0,0,0,2"
                                BorderBrush="#4F5D9E"
                                Background="Transparent"
                                FontFamily="Segoe UI Semibold"
                                FontSize="13"
                                Foreground="#4F5D9E"
                                Cursor="Hand"/>
                        <Button x:Name="btnTabRegister" Grid.Column="1"
                                Content="Регистрация"
                                Click="TabRegister_Click"
                                Height="36"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Background="Transparent"
                                FontSize="13"
                                Foreground="#B0B8C8"
                                Cursor="Hand"/>
                    </Grid>

                    <!-- ВХОД -->
                    <StackPanel x:Name="panelLogin">
                        <TextBlock Text="ИМЯ ПОЛЬЗОВАТЕЛЯ"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="tbLoginUser"
                                 Height="38" Margin="0,0,0,12"
                                 Foreground="#0F1117" Background="White"
                                 BorderBrush="#D0D5E0" BorderThickness="1"
                                 Padding="10,8" FontSize="13"
                                 VerticalContentAlignment="Center"/>

                        <TextBlock Text="ПАРОЛЬ"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <PasswordBox x:Name="pbLoginPass"
                                     Height="38" Padding="10,9"
                                     FontSize="13"
                                     Foreground="#0F1117" Background="White"
                                     BorderBrush="#D0D5E0" BorderThickness="1"
                                     Margin="0,0,0,8"/>

                        <TextBlock x:Name="tbLoginError"
                                   Style="{StaticResource ErrorTextStyle}"
                                   Margin="0,0,0,12"
                                   Visibility="Collapsed"/>

                        <Button Content="Войти"
                                Click="Login_Click"
                                Height="40"
                                Style="{StaticResource PrimaryButtonStyle}"
                                FontSize="14" Padding="0"/>
                    </StackPanel>

                    <!-- РЕГИСТРАЦИЯ -->
                    <StackPanel x:Name="panelRegister" Visibility="Collapsed">
                        <TextBlock Text="ИМЯ ПОЛЬЗОВАТЕЛЯ"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="tbRegUser"
                                 Height="38" Margin="0,0,0,12"
                                 Foreground="#0F1117" Background="White"
                                 BorderBrush="#D0D5E0" BorderThickness="1"
                                 Padding="10,8" FontSize="13"
                                 VerticalContentAlignment="Center"/>

                        <TextBlock Text="ПОЛНОЕ ИМЯ (ФИО)"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="tbRegName"
                                 Height="38" Margin="0,0,0,12"
                                 Foreground="#0F1117" Background="White"
                                 BorderBrush="#D0D5E0" BorderThickness="1"
                                 Padding="10,8" FontSize="13"
                                 VerticalContentAlignment="Center"/>

                        <TextBlock Text="EMAIL"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="tbRegEmail"
                                 Height="38" Margin="0,0,0,4"
                                 Foreground="#0F1117" Background="White"
                                 BorderBrush="#D0D5E0" BorderThickness="1"
                                 Padding="10,8" FontSize="13"
                                 VerticalContentAlignment="Center"/>
                        

                        <TextBlock Text="ПАРОЛЬ"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <PasswordBox x:Name="pbRegPass"
                                     Height="38" Padding="10,9"
                                     FontSize="13"
                                     Foreground="#0F1117" Background="White"
                                     BorderBrush="#D0D5E0" BorderThickness="1"
                                     Margin="0,0,0,12"/>

                        <TextBlock Text="ПОВТОРИТЕ ПАРОЛЬ"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <PasswordBox x:Name="pbRegPass2"
                                     Height="38" Padding="10,9"
                                     FontSize="13"
                                     Foreground="#0F1117" Background="White"
                                     BorderBrush="#D0D5E0" BorderThickness="1"
                                     Margin="0,0,0,8"/>

                        <TextBlock x:Name="tbRegError"
                                   Style="{StaticResource ErrorTextStyle}"
                                   Margin="0,0,0,12"
                                   Visibility="Collapsed"/>

                        <Button Content="Зарегистрироваться"
                                Click="Register_Click"
                                Height="40"
                                Style="{StaticResource PrimaryButtonStyle}"
                                FontSize="14" Padding="0"/>
                    </StackPanel>

                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
    </ScrollViewer>
</Window>
