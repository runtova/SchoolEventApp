<Window x:Class="SchoolEventApp.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Предпросмотр печати"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        MinWidth="800" MinHeight="600"
        FontFamily="Segoe UI" FontSize="13">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A252F" Padding="12,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="🖨️  Предпросмотр печати"
                           Foreground="White" FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnPrint" Content="🖨️  Печатать"
                            Click="btnPrint_Click"
                            Width="120" Margin="0,0,8,0" Padding="0,7"
                            Background="#27AE60" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="btnClose" Content="✖  Закрыть"
                            Click="btnClose_Click"
                            Width="100" Padding="0,7"
                            Background="#E74C3C" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Background="#525659"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <WebBrowser x:Name="webBrowser" Margin="20"
                        MinWidth="794" MinHeight="1123"/>
        </ScrollViewer>
    </Grid>
</Window>