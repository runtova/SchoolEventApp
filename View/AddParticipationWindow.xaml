<Window x:Class="SchoolEventApp.AddParticipationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить участие" Height="293" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="Добавление записи об участии"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <TextBlock Text="Мероприятие:"/>
        <ComboBox x:Name="cbEvent" Margin="0,3,0,12"
                  DisplayMemberPath="DisplayText"
                  SelectedValuePath="event_cod"/>

        <TextBlock Text="Участник:"/>
        <ComboBox x:Name="cbStudent" Margin="0,3,0,15"
                  DisplayMemberPath="DisplayText"
                  SelectedValuePath="student_cod"/>

        <TextBlock x:Name="tbError" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,10"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="💾 Сохранить" Click="Save_Click" Width="110" Margin="0,0,8,0"
                    Background="#9B59B6" Foreground="White" BorderThickness="0" Padding="0,6"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80" Padding="0,6"/>
        </StackPanel>
    </StackPanel>
</Window>
